# Supabase — public client config (safe to expose; RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Helius (Solana RPC) — SERVER-ONLY secret (no NEXT_PUBLIC prefix)
HELIUS_API_KEY=your-helius-api-key
# Devnet-first phase: defaults to devnet in code; set "mainnet" to go live.
SOLANA_NETWORK=devnet

# Network switch (CLIENT) — default cluster for the in-app devnet/mainnet toggle.
# Devnet-first: defaults to devnet in code. Set "mainnet" for the live phase.
# Users can flip it at runtime; their choice is saved to localStorage.
NEXT_PUBLIC_SOLANA_NETWORK=devnet
# Optional browser-safe RPC endpoints per cluster (falls back to public clusterApiUrl).
NEXT_PUBLIC_SOLANA_RPC=
NEXT_PUBLIC_SOLANA_RPC_DEVNET=

# GitHub — SERVER-ONLY, optional. Enables the live "latest commits" feed on the
# token page for private repos and lifts the 60 req/hr unauthenticated limit.
# A fine-grained PAT with read-only "Contents" access is enough. Falls back to
# the static commit list when unset.
GITHUB_TOKEN=

# Telegram — SERVER-ONLY, optional. Bot token (from @BotFather) for the per-project
# read-only build-update bot (lib/telegram-send.ts). When set, the agent runtime
# can broadcast build progress to a project's chat; unset = every send is a safe
# no-op (the pure formatter in lib/telegram.ts still works). NEVER expose.
TELEGRAM_BOT_TOKEN=

# Launchpad — SERVER-ONLY. Selects how a launch mints its token (lib/launchpad.ts).
# Unset/"simulated" = prototype mode (no on-chain mint; RLS-safe insert).
# "spl"     → mint a real SPL token directly (needs LAUNCH_SIGNER_SECRET; great for devnet).
# "pumpfun" → Pump.fun (needs PUMPPORTAL_API_KEY); "bags" → Bags.fun (needs BAGS_API_KEY).
LAUNCHPAD_PROVIDER=simulated
# Cluster a real launch mints on: mainnet | devnet (the UI switch can override per launch)
LAUNCH_CLUSTER=devnet
# Signer that pays for + owns a real "spl" launch — a JSON array of the 64-byte
# secret key (solana-keygen format). Its pubkey doubles as the treasury wallet.
# On devnet, fund it from the faucet; on mainnet it must hold real SOL.
LAUNCH_SIGNER_SECRET=
PUMPPORTAL_API_KEY=
BAGS_API_KEY=

# Supabase service-role key — SERVER-ONLY secret. Required only for real launches
# (persisting a mint/treasury_wallet bypasses the locked-down anon insert policy).
# Leave unset in prototype mode. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# LOOP stake gate — SERVER-ONLY. The LOOP token mint address. When set, launching
# requires a verified wallet (signature proof) holding >= 1,000 LOOP on the launch
# cluster, checked on-chain (lib/stake.ts). Unset = stake gate open (prototype).
LOOP_MINT=

# Vanity mint addresses — SERVER-ONLY. When MINT_VANITY_SUFFIX is set, a real
# "spl" launch mints at an address ending in that suffix (e.g. every CA ends in
# "Loop"), drawn from VANITY_POOL: a JSON array of 64-byte secret-key arrays
# pre-ground offline (`solana-keygen grind --ends-with Loop:N`, ~40s each) and
# assembled with `node scripts/build-vanity-pool.cjs`. A keypair is consumed when
# its mint account first appears on-chain (no DB needed). STRICT: when the suffix
# is set, a launch FAILS rather than mint a non-matching address if the pool is
# empty — so every published CA ends in the suffix. Keep the pool replenished.
# Unset = random addresses (default).
MINT_VANITY_SUFFIX=
VANITY_POOL=
