# Supabase — public client config (safe to expose; RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Helius (Solana RPC) — SERVER-ONLY secret (no NEXT_PUBLIC prefix)
HELIUS_API_KEY=your-helius-api-key
SOLANA_NETWORK=mainnet

# GitHub — SERVER-ONLY, optional. Enables the live "latest commits" feed on the
# token page for private repos and lifts the 60 req/hr unauthenticated limit.
# A fine-grained PAT with read-only "Contents" access is enough. Falls back to
# the static commit list when unset.
GITHUB_TOKEN=

# Launchpad — SERVER-ONLY. Selects how a launch mints its token (lib/launchpad.ts).
# Unset/"simulated" = prototype mode (no on-chain mint; RLS-safe insert).
# "pumpfun" → Pump.fun (needs PUMPPORTAL_API_KEY); "bags" → Bags.fun (needs BAGS_API_KEY).
LAUNCHPAD_PROVIDER=simulated
# Cluster a real launch mints on: mainnet | devnet
LAUNCH_CLUSTER=mainnet
PUMPPORTAL_API_KEY=
BAGS_API_KEY=

# Supabase service-role key — SERVER-ONLY secret. Required only for real launches
# (persisting a mint/treasury_wallet bypasses the locked-down anon insert policy).
# Leave unset in prototype mode. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
