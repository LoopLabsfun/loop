# Supabase — public client config (safe to expose; RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Public site origin (lib/site.ts) — used for canonical/OG/sitemap/manifest and
# the wallet's redirect URLs. Defaults to https://looplabs.fun in code; override
# only for a different deploy (preview/staging).
NEXT_PUBLIC_SITE_URL=

# Privy — OPTIONAL embedded-wallet login (PUBLIC client app id; safe to expose).
# When unset, the PrivyAuthProvider is a pass-through — users still connect with
# the real Phantom/Solflare wallet-adapter (lib/wallet.tsx); only the embedded
# Privy login (Google/Twitter/GitHub/Telegram + Solana wallet, configured in
# lib/privy.tsx, must match the Privy dashboard) is off. (Server-side
# PRIVY_APP_SECRET powers the agent-wallet custody — see below.)
NEXT_PUBLIC_PRIVY_APP_ID=
# Privy SERVER-ONLY creds (lib/agent-wallet.ts) — powers per-project agent-wallet
# custody (create/sign via Privy's server SDK). Both must be set together; unset
# = agent-wallet custody is off (no real signing). Get from the Privy dashboard.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Helius (Solana RPC) — SERVER-ONLY secret (no NEXT_PUBLIC prefix)
HELIUS_API_KEY=your-helius-api-key
# Live phase: defaults to mainnet in code; set "devnet" for the test cluster.
SOLANA_NETWORK=mainnet

# Hood (Robinhood Chain, EVM id 4663) — see docs/multichain-hood.md. The public
# RPC needs no key; override with a keyed provider under load. Optional.
HOOD_RPC_URL=
# Default chain for the header's Solana/Hood switch ("solana" unless set to "hood").
NEXT_PUBLIC_DEFAULT_CHAIN=
# HoodLauncher contract address once deployed on 4663 (Phase 3+ trading/launch).
NEXT_PUBLIC_HOOD_LAUNCHER_ADDRESS=

# Network switch (CLIENT) — default cluster for the in-app devnet/mainnet toggle.
# Live phase: defaults to mainnet in code. Set "devnet" for the test cluster.
# Users can flip it at runtime; their choice is saved to localStorage.
NEXT_PUBLIC_SOLANA_NETWORK=mainnet
# Optional browser-safe RPC override per cluster. By DEFAULT the browser wallet
# now uses the same-origin server proxy `/api/rpc` → Helius (key stays server-side)
# for everything — blockhash, simulate, send, confirm — plus `/api/wallet-balance`
# for the "Max" amount. The public clusterApiUrl 403s browser requests, so set
# these only if you have your own browser-safe RPC and want to bypass the proxy.
NEXT_PUBLIC_SOLANA_RPC=
NEXT_PUBLIC_SOLANA_RPC_DEVNET=

# Public launches gate. Phase A (LOOP-only) keeps this UNSET/false → visitors
# can't create projects (server action refuses + RLS forbids anon inserts + UI
# shows "opens soon"). LOOP itself is created via the service-role launch script,
# unaffected. Set "true" to reopen launches for the invite/public phase.
NEXT_PUBLIC_LAUNCHES_OPEN=

# GitHub — SERVER-ONLY, optional. Enables the live "latest commits" feed on the
# token page for private repos and lifts the 60 req/hr unauthenticated limit.
# A fine-grained PAT with read-only "Contents" access is enough. Falls back to
# the static commit list when unset. ALSO the execution gate for white-label
# provisioning (lib/provisioning.ts): with write access to the Loop org, a launch
# auto-creates the project's repo under it. Unset = the repo plan computes but
# nothing is created.
GITHUB_TOKEN=
# White-label provisioning (lib/provisioning.ts). The Loop-owned GitHub org every
# project's repo lives under, so the UI shows LoopLabsfun/<slug>, never a personal
# account. Defaults to "LoopLabsfun" when unset. The agent pushes/deploys here.
GITHUB_ORG=LoopLabsfun
# Vercel — SERVER-ONLY, optional. The execution gate for auto-deploying each
# project under a Loop-owned team (lib/provisioning.ts). Need BOTH a token and the
# team id. Unset = the deploy plan computes but nothing is created.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
# Vercel Web Analytics — powers the "Visitors" stat in Autonomous work (lib/
# vercel-analytics.ts): total visitors since launch, read with VERCEL_TOKEN.
# Vercel has NO documented analytics read API, so this hits the dashboard's
# internal endpoint and is best-effort — unset/failed ⇒ the UI shows "—". Needs
# the project id; the endpoint path is overridable in case Vercel moves it.
VERCEL_PROJECT_ID=
VERCEL_ANALYTICS_ENDPOINT=

# Telegram — SERVER-ONLY, optional. Bot token (from @BotFather) for the per-project
# read-only build-update bot (lib/telegram-send.ts). When set, the agent runtime
# can broadcast build progress to a project's chat; unset = every send is a safe
# no-op (the pure formatter in lib/telegram.ts still works). NEVER expose.
TELEGRAM_BOT_TOKEN=
# Chat/channel id the runtime broadcasts shipped-build updates to (Phase 1: one
# chat for the LOOP dogfood; per-project chats come with a telegram_chat_id
# column later). Both this AND TELEGRAM_BOT_TOKEN must be set to send.
TELEGRAM_CHAT_ID=
# Optional: route the BUILD-LOG to the discussion group's "Agent Activity" topic
# instead of the broadcast channel above. When CHAT_ID is set the dev-log is sent
# there (into the THREAD_ID topic), keeping the channel curated/marketing-only.
# Set the linked supergroup id (-100…) + the topic's message_thread_id. See
# docs/telegram-launch.md and docs/agent-marketing.md.
TELEGRAM_BUILDLOG_CHAT_ID=
TELEGRAM_BUILDLOG_THREAD_ID=

# Discord — SERVER-ONLY, optional. Two ways to wire the agent's Discord presence:
#  1) DISCORD_WEBHOOK_URL — read-only broadcast (an incoming webhook). Simplest;
#     the agent can only POST the build-log. Unset = every send is a safe no-op.
#  2) The BOT (token + guild) — full control: the agent creates/maintains channels
#     (lib/discord-bot.ts), posts the build-log to #build-log, AND READS #general/
#     #ideas each tick into memory (lib/discord-read.ts → discord_messages, surfaced
#     as untrusted community chatter in the decision prompt). Preferred when set:
#     deliverBuildLog() posts via the bot over the webhook.
# Enable Message Content Intent on the bot so it can read message text. NEVER expose.
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Optional: the #build-log channel id the bot posts to. Unset = resolved by the
# "build-log" channel name each time.
DISCORD_BUILDLOG_CHANNEL_ID=

# --- Agent marketing skill (docs/agent-marketing.md) ---
# AGENT_MARKETING=1 swaps the weak "dev-log" posting guidance for the marketing
# module (audience model + content rotation + holder-value bar). Off = legacy.
AGENT_MARKETING=
# Fuzzy anti-repetition: reject a post whose token-similarity to a recent one is
# ≥ this (0..1, e.g. 0.6). Unset = only exact-duplicate text is blocked.
AGENT_POST_SIMILARITY=
# How many recent posts (per platform) to compare against. Default 5.
AGENT_RECENT_POSTS=

# Public social identities shown in the "Autonomous work" header. BROWSER-SAFE
# (no secret). The agent's email is always real; X / Telegram show "soon" until
# these are set to the REAL handle/username, then they render as live links.
# No leading @ — e.g. NEXT_PUBLIC_X_HANDLE=loop_fun, NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=LoopAgentBot
NEXT_PUBLIC_X_HANDLE=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# X (Twitter) posting — SERVER-ONLY, optional. The 4 OAuth 1.0a creds that let
# the agent post (lib/x-send.ts). X_API_KEY/SECRET are the Go Disrupt developer
# app's CONSUMER key/secret; X_ACCESS_TOKEN/SECRET authorize the posting account
# (@looplabsfun) and are obtained once via `npx tsx scripts/x-auth.ts` (PIN flow,
# sign in as @looplabsfun). All 4 must be set to post; unset = every tweet is a
# safe no-op. The access tokens don't expire. NEVER expose (no NEXT_PUBLIC_).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Email — SERVER-ONLY, optional. Provider key for the agent's outreach mailbox
# <slug>@agents.looplabs.fun (lib/email-send.ts, Resend). When set, the agent can
# send intros/answers; unset = every send is a safe no-op. Receiving replies
# needs a real domain (buy loop.fun) + Cloudflare Email Routing → an inbound
# webhook into agent_emails (see docs/mainnet-readiness.md). NEVER expose.
RESEND_API_KEY=
# Agent mail domain — PUBLIC, optional. Defaults to "agents.looplabs.fun". This
# MUST equal a domain you've VERIFIED in Resend, or every send 4xx's ("domain not
# verified"). If you verified the apex (looplabs.fun) instead of the subdomain,
# set this to "looplabs.fun" so the agent sends from <slug>@looplabs.fun. Public
# (not secret) so the client-rendered identity row matches the server send-from.
NEXT_PUBLIC_AGENT_EMAIL_DOMAIN=
# Autonomous email send — SERVER-ONLY, opt-in, OUTWARD-FACING. "1" lets the agent
# actually SEND one real outreach email per tick from its mailbox (it returns an
# "email" {to,subject,body} in its decision; validated single recipient, never
# itself). Default OFF = the capability isn't even offered to the brain. Needs
# RESEND_API_KEY + a verified domain. Protects the domain's reputation with a
# daily cap below. Flip to "1" only when you want the agent emailing real people.
AGENT_EMAIL_SEND=
# Max autonomous emails per project per rolling 24h (default 20) — reputation
# guard so the agent can't blast the domain. Only used when AGENT_EMAIL_SEND=1.
AGENT_EMAIL_MAX_PER_DAY=

# Agent chat price — PUBLIC, optional. Base $LOOP a holder sends (to the project
# treasury) to ask the agent one question; a boost on top jumps the answer queue.
# Defaults to 1000. Shown in the UI, so it's public (not secret).
NEXT_PUBLIC_CHAT_LOOP_PRICE=
# Autonomous chat answering — SERVER-ONLY, opt-in. "1" lets the agent spend
# tokens answering paid chat questions on its cron run (highest boost first).
# Payments are verified on-chain before a question is recorded (submitChatAction),
# so this is a COST / go-live switch, not a safety one. Default OFF: recording +
# the chat UI work regardless; flip to "1" when you want the agent replying.
AGENT_CHAT_ANSWER=
# Model for answering paid holder chat — SERVER-ONLY, optional. A 1-3 sentence
# Q&A doesn't need the build brain (Opus 4.8), so chat replies default to Haiku
# 4.5 (~15-20× cheaper per answer). Set to claude-opus-4-8 to use Opus instead.
# Only the chat path is affected; the decision/build loop always uses Opus.
AGENT_CHAT_MODEL=

# LLM router (lib/llm.ts) — SERVER-ONLY, optional. The agent's short, stateless
# "family B" calls (paid holder chat, community Q&A, social authoring) go through
# one provider seam. Default (unset) = Anthropic, byte-identical to before. Set
# LLM_CHAT_PROVIDER=groq (+ GROQ_API_KEY) to route THOSE calls to Groq's fast,
# free/cheap OpenAI-compatible API instead — cuts the Anthropic bill without
# touching the coding "hands" (the Claude Agent SDK), which stay on Claude.
LLM_CHAT_PROVIDER=
GROQ_API_KEY=
# Groq chat model (open-weight). Default: llama-3.3-70b-versatile.
GROQ_CHAT_MODEL=

# Launchpad — SERVER-ONLY. Selects how a launch mints its token (lib/launchpad.ts).
# Unset/"simulated" = prototype mode (no on-chain mint; RLS-safe insert).
# "spl"     → mint a real SPL token directly (needs LAUNCH_SIGNER_SECRET; great for devnet).
# "pumpfun" → Pump.fun (needs PUMPPORTAL_API_KEY); "bags" → Bags.fun (needs BAGS_API_KEY).
LAUNCHPAD_PROVIDER=simulated
# Cluster a real launch mints on: mainnet | devnet (the UI switch can override per launch)
LAUNCH_CLUSTER=mainnet
# Signer that pays for + owns a real "spl" launch — a JSON array of the 64-byte
# secret key (solana-keygen format). Its pubkey doubles as the treasury wallet.
# On devnet, fund it from the faucet; on mainnet it must hold real SOL.
LAUNCH_SIGNER_SECRET=
PUMPPORTAL_API_KEY=
BAGS_API_KEY=

# Pay-to-launch (the launch toll). When BOTH are set, launching requires a signed
# wallet proof AND an on-chain SOL payment of LAUNCH_FEE_SOL to LAUNCH_FEE_WALLET,
# verified server-side (lib/solana verifySolPayment) and replay-guarded by the
# payment signature — closing the free-spam surface of open launches. Leave unset
# to keep launches untolled (the LOOP-only phase + devnet). Server-only.
LAUNCH_FEE_SOL=
LAUNCH_FEE_WALLET=

# One-off mainnet launch script (scripts/mainnet-launch-loop.ts) — the LOOP
# token's own social links + an initial dev buy (SOL) spent on-chain at creation.
# Not read by the app at runtime; only needed when re-running that script.
LOOP_TWITTER=
LOOP_TELEGRAM=
LOOP_DEV_BUY_SOL=

# Supabase service-role key — SERVER-ONLY secret. Required only for real launches
# (persisting a mint/treasury_wallet bypasses the locked-down anon insert policy).
# Leave unset in prototype mode. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# LOOP stake gate — SERVER-ONLY. The LOOP token mint address. When set, launching
# requires a verified wallet (signature proof) holding >= 1,000 LOOP on the launch
# cluster, checked on-chain (lib/stake.ts). Unset = stake gate open (prototype).
LOOP_MINT=

# Vanity mint addresses — SERVER-ONLY. When MINT_VANITY_SUFFIX is set, a real
# "spl" launch mints at an address ending in that suffix (e.g. every CA ends in
# "Loop"), drawn from VANITY_POOL: a JSON array of 64-byte secret-key arrays
# pre-ground offline (`solana-keygen grind --ends-with Loop:N`, ~40s each) and
# assembled with `node scripts/build-vanity-pool.cjs`. A keypair is consumed when
# its mint account first appears on-chain (no DB needed). STRICT: when the suffix
# is set, a launch FAILS rather than mint a non-matching address if the pool is
# empty — so every published CA ends in the suffix. Keep the pool replenished.
# Unset = random addresses (default).
MINT_VANITY_SUFFIX=
VANITY_POOL=

# Quiet relaunch mode — SERVER-ONLY. When "1", the agent goes SILENT: it stops ALL
# public posting (X + Telegram) and the system prompt refocuses it on silent
# self-improvement — auditing its own codebase for inconsistencies and perfecting
# its own UI (app/ + components/) with small tested commits. The on-site task feed
# still records every increment; only the broadcasts are off. Use it to keep
# building/relaunching without re-activating the audience. Unset/"0" = build in
# public normally. (AGENT_X_PAUSED=1 still pauses ONLY X if you want Telegram on.)
AGENT_SOCIAL_SILENT=
# Agent runtime — SERVER-ONLY. The per-project AI worker (lib/agent-runtime.ts):
# given a project's mandate + steering directives + tasks, it asks Claude for the
# next build action and persists it to agent_tasks/agent_posts (needs the
# service-role key above). Unset ANTHROPIC_API_KEY = simulated UI only (no-op).
ANTHROPIC_API_KEY=
# Real Claude API spend — the "Compute" line + remaining credit on the official
# project (lib/anthropic-cost.ts). The Admin **Cost API** needs an ADMIN key
# (sk-ant-admin01-…, created in Console → Settings; requires an org), separate
# from ANTHROPIC_API_KEY. Unset ⇒ Compute shows the modeled estimate + "—".
ANTHROPIC_ADMIN_KEY=
# Starting Claude credit (USD). Anthropic exposes spend but not a live balance,
# so "remaining credit" = this − measured spend. Unset ⇒ no remaining line.
ANTHROPIC_STARTING_CREDIT_USD=
# RFC3339 "since" for spend + visitor totals (default = LOOP launch, 2026-06-16).
ANTHROPIC_COST_SINCE=
# Expense ledger (lib/ledger.ts) — the real fixed bills behind the official
# project's "Ledger · real bills" card. All OPTIONAL: sensible real defaults are
# baked in (Vercel $20/mo, E2B $5/mo, X Premium $5/mo, DEX Screener $299 one-off);
# set these only to correct a price without a code change. Compute is metered live
# (ANTHROPIC_ADMIN_KEY above), not a fixed line.
LEDGER_VERCEL_USD=
LEDGER_E2B_USD=
LEDGER_X_USD=
LEDGER_DEXSCREENER_USD=
# How deep the agent may EXPLORE the codebase before it acts (the iterative read
# loop). The brain reads real files before editing, but historically got ONE read
# round (≤6 files, then act) — so on non-trivial work it edited half-blind. Set the
# max read→reflect→read-more rounds here (e.g. 4): it reads a file, discovers what
# it imports, reads those too, THEN edits. This is the single biggest lever on the
# agent's "intelligence". Each round is another Opus call, so it's bounded (cap 6).
# Unset/1 = the original single-round behavior (safe default). Optional companion
# AGENT_READ_MAX_FILES caps total files fetched across rounds (default rounds*6).
AGENT_READ_ROUNDS=
AGENT_READ_MAX_FILES=
# Prompt caching — ON by default; set to "0" to disable. Behavior-preserving (the
# model's output is identical): it caches the system prompt + current-state user
# turn so the read-loop rounds and forcing turn within a tick re-read that prefix
# at ~0.1x input cost instead of full price. With AGENT_READ_ROUNDS>1 one tick makes
# several Opus calls over that prefix, so this is the dominant token-cost lever.
AGENT_PROMPT_CACHE=
# Thinking-effort dial (Opus 4.8). Unset = "high" (current behavior). Set to
# low|medium|high|max to trade intelligence for fewer thinking tokens — a pure cost
# lever with no code change. "medium" is a good cost/quality balance to try first.
AGENT_EFFORT=
# Agent SDK HANDS — SERVER-ONLY, opt-in, HIGH-IMPACT. When "1", a CODE task's
# execution is delegated to a bounded Claude Agent SDK session running INSIDE the
# E2B sandbox (lib/agent-sdk-hands.ts + scripts/agent-sdk-session.mjs): it reads/
# edits/runs the tests ITSELF (Claude-Code-style), then we denylist-check the diff,
# run the independent gate, and push if green. Takes precedence over the
# AGENT_REPO_HANDS edits path for feature/fix tasks. Needs E2B_API_KEY +
# GITHUB_TOKEN + ANTHROPIC_API_KEY and the loop-agent-sdk template (below). The
# session runs WITHOUT the GitHub token (can't push/exfiltrate). Unset = off.
AGENT_SDK_HANDS=
# Warm E2B template WITH the Agent SDK + claude binary baked in (build with
# `E2B_TEMPLATE_NAME=loop-agent-sdk npx tsx scripts/e2b-template.ts`). Point
# E2B_TEMPLATE at it when AGENT_SDK_HANDS=1 so the session starts fast.
# Model for the in-sandbox session — defaults to claude-sonnet-4-6 (cheap; the
# iteration compensates). Set to claude-opus-4-8 for harder work (costlier).
AGENT_SDK_MODEL=
# Bounds on the (expensive) session: max agent turns (default 24, cap 60), hard
# wall-clock ms (default 150000), sandbox timeout ms (default 260000, under the
# 300s cron cap), and a stateless cost throttle so it runs at most ~once per
# AGENT_SDK_MIN_INTERVAL_MS (default 900000 = 15 min; 0 = every eligible tick).
AGENT_SDK_MAX_TURNS=
AGENT_SDK_WALL_MS=
AGENT_SDK_TIMEOUT_MS=
AGENT_SDK_MIN_INTERVAL_MS=
# Brain mode — SERVER-ONLY. "legacy" (default/unset) runs the whole tick inline in
# the 300s Vercel cron (decide + repo-hands edits). "sdk" makes the cron the cheap
# heartbeat/brain that DECIDES, then ENQUEUES the long-running SDK-in-E2B session on
# Trigger.dev (no 300s cap) — lib/agent-session-enqueue.ts + trigger/agent-session.ts.
# With "sdk", the bigger AGENT_SDK_* defaults apply (wall ~10min, timeout ~16min).
AGENT_BRAIN=
# Trigger.dev — the durable orchestrator for AGENT_BRAIN=sdk. SERVER-ONLY secret
# the Vercel side uses to enqueue runs (tasks.trigger). Get it from the Trigger.dev
# dashboard (Project → API keys, the `tr_prod_…`/`tr_dev_…` SECRET key). The WORKER
# side needs its OWN env set IN the Trigger.dev dashboard (not Vercel): E2B_API_KEY,
# E2B_TEMPLATE, GITHUB_TOKEN, ANTHROPIC_API_KEY, AGENT_TICK_SECRET, and LOOP_SITE_URL
# (the app origin the session POSTs results back to). Project ref is in trigger.config.ts.
TRIGGER_SECRET_KEY=
# Shared secret gating POST /api/agent/tick (sent as the x-agent-secret header by
# your scheduler/cron). Unset = the endpoint refuses all calls.
AGENT_TICK_SECRET=
# Vercel Cron auth: set this and Vercel signs the hourly /api/agent/cron request
# with `Authorization: Bearer $CRON_SECRET` (see vercel.json). Unset = cron refused.
CRON_SECRET=
# E2B sandbox — the agent's "hands". When set, a tick may run real code
# (python/javascript/bash) in an isolated sandbox and fold the output into the
# build log (lib/sandbox.ts). Unset = the agent plans without executing.
E2B_API_KEY=
# Custom WARM sandbox template (build with `npx tsx scripts/e2b-template.ts`):
# code-interpreter base + git + a pre-warmed npm cache from package-lock.json.
# Set to its name (e.g. "loop-agent") so the repo-hands gate (clone → npm ci → tsc
# → tests) hits the cache and fits the cron budget instead of cold-installing each
# cycle. Unset = E2B's default base image (cold npm ci ⇒ gate likely times out).
E2B_TEMPLATE=
# Add `next build` to the repo-hands gate ("1" = on). Catches route/build breakage
# that typecheck + unit tests miss, at the cost of the heaviest gate step — only
# worth it with E2B_TEMPLATE set (the warm cache buys the time). Unset = skip build.
AGENT_GATE_BUILD=
# Repo-committing hands — SERVER-ONLY, opt-in, HIGH-IMPACT. When "1", the agent's
# `edits` are applied in an E2B sandbox that clones the repo, runs the gate
# (install → typecheck → tests), and PUSHES TO main only if green — i.e. the agent
# ships REAL code autonomously, which auto-deploys (lib/repo-hands.ts). Needs
# E2B_API_KEY + a write-scoped GITHUB_TOKEN. The agent can never edit its own
# safety rails/secrets/CI (denylist). Unset/anything else = the agent proposes
# edits but nothing is applied. Flip to "1" only when you're ready to let it push.
AGENT_REPO_HANDS=
# Autonomous creator-fee claim — SERVER-ONLY, opt-in. When "1", each agent cron
# sweeps accrued pump.fun creator fees into the treasury via PumpPortal, signing a
# REAL mainnet tx with LAUNCH_SIGNER_SECRET (lib/creator-fees.ts). For LOOP the
# pump.fun creator IS the treasury wallet, so the claim directly refills the
# balance the budget gate reads — closing the self-funding loop. Unset/anything
# else = no claim (the agent still ticks while the treasury is funded). Costs only
# a tiny priority fee per claim; it COLLECTS fees owed, it does not spend treasury.
AGENT_CLAIM_FEES=
# Physical fee distribution — the agent + platform shares of swept creator fees
# are disbursed out of the custodial creator wallet into their own wallets, making
# the 30/65/5 split REAL money movement (lib/fee-distribute.ts + scripts/distribute-
# fees.ts). PLATFORM_WALLET is the 5% cut destination (base58). The script is
# manual + dry-run by default; FEE_DISTRIBUTE=1 arms the real --execute transfers
# (founder runs it after testing). The agent wallet is read from the project row;
# the founder 30% stays in the creator==treasury wallet. FEE_MIN_TRANSFER_SOL is
# the dust floor (default 0.001). All unset = no distribution (accounting only).
PLATFORM_WALLET=
FEE_DISTRIBUTE=
FEE_MIN_TRANSFER_SOL=
# Build-cost throttle — SERVER-ONLY, opt-in. When "1", the agent stamps a
# `[no-deploy]` body marker on its commits so Vercel's ignoreCommand (vercel.json)
# SKIPS the production build — except once per DEPLOY_MIN_INTERVAL_MIN, when it
# omits the marker so that commit deploys and ships the whole accumulated batch
# ("plusieurs commits, 1 deploy"; lib/deploy-throttle.ts). Commits still ALL land
# on main (public + verifiable on GitHub) regardless. Unset/anything else = every
# push builds, as today. Humans' / manual commits never carry the marker, so they
# always deploy. Flip to "1" to cap Vercel build spend.
DEPLOY_THROTTLE=
# Minutes between throttled production deploys (default 60). At most ~1 build per
# this interval while the agent commits continuously. Only used when DEPLOY_THROTTLE=1.
DEPLOY_MIN_INTERVAL_MIN=
# Compute rail (lib/compute-rail.ts) — how the agent pays its own bills. Providers
# bill in fiat, projects earn SOL, so Loop is the custodial rail: it converts the
# agent's *own* fee share (SOL → USDC) to top up its provider account, metered per
# project. Set to the provider name (e.g. "anthropic") to enable real conversion;
# unset = no auto-convert (the credit accounting still computes for the UI).
COMPUTE_RAIL_PROVIDER=
# Inbound email webhook (app/api/email/inbound). A real domain's email router
# (Cloudflare Email Routing / Resend inbound) POSTs each message received at
# <slug>@agents.looplabs.fun here; the route stores it in agent_emails so the agent
# can read + reply. Shared secret the router's worker sends as `x-email-secret`.
# Unset = the endpoint refuses all calls. Needs SUPABASE_SERVICE_ROLE_KEY to write.
EMAIL_INBOUND_SECRET=
